m4_include([package.m4])
m4_include([test_macros.at])

include_test_inputs([libcfile])

dnl Runs test file on a device
m4_define([RUN_TEST_FILE_WITH_DEVICE],
  [m4_foreach_w(
    [test_file],
    [/dev/ada0 /dev/da0 /dev/sda /dev/vda /dev/vtbd0],
    [m4_syscmd([test -r ]test_file)

    m4_if(
      m4_sysval,
      [0],
      [m4_define(
        [test_binary],
        [m4_expand(test_prefix[]_test_file)])dnl

      m4_define([sanitized_test_file],
        [m4_translit([test_file], [[],[],[]"'`\], [______])])

      AT_SETUP(test_binary with input: 'sanitized_test_file')

      AT_SKIP_IF(
        [test -n "${SKIP_LIBRARY_TESTS}"])

      AT_CHECK(
        [OSTYPE_LOWER=`echo "$OSTYPE" | tr '[A-Z]' '[a-z]'`
        case "${OSTYPE_LOWER}" in
          cygwin*|msys*)
            exit 77
            ;;

          *)
            ath_fn_run_test_binary test_binary test_input
            ;;
        esac
        ])

      AT_CLEANUP])
    ])
  ])

dnl Wrap m4_define to overwrite AT_TESTSUITE_NAME
m4_define([_M4_DEFINE_HOOK], m4_defn([m4_define]))
m4_define([m4_define],
  [m4_if(
    [$1],
    [AT_TESTSUITE_NAME],
    [_M4_DEFINE_HOOK([$1], [Running library tests])],
    [_M4_DEFINE_HOOK([$1], [$2])])])

dnl Redefine AS_BOX to remove the "box"
m4_undefine([AS_BOX])
m4_define([AS_BOX], [echo "$1"])

AT_INIT([library])
AT_COLOR_TESTS

dnl Rewrite AT_SETUP to change the minimum line length
m4_define([AT_SETUP],
  m4_unquote(
    [m4_bpatsubst(
      m4_dquote(m4_defn([AT_SETUP])),
      [47],
      [72])
    ])
  )

SETUP_HELPER_FUNCTIONS

RUN_TEST_BINARIES(
  [SKIP_LIBRARY_TESTS],
  [error notify support system_string winapi])

RUN_TEST_BINARIES_WITH_INPUT(
  [SKIP_LIBRARY_TESTS],
  [file],
  test_inputs_libcfile)

RUN_TEST_FILE_WITH_DEVICE
